# ====================================
# AI Phone Configuration
# ====================================
# Copy this to .env and fill in your values

# ====================================
# Network Configuration
# ====================================

# Your server's LAN IP (CRITICAL for RTP audio)
# This IP goes into SDP packets so FreePBX knows where to send audio
EXTERNAL_IP=10.0.0.100

# ====================================
# Drachtio Configuration
# ====================================

DRACHTIO_HOST=127.0.0.1
DRACHTIO_PORT=9022
DRACHTIO_SECRET=cymru
DRACHTIO_SIP_PORT=5070

# ====================================
# FreeSWITCH Configuration
# ====================================

FREESWITCH_HOST=127.0.0.1
FREESWITCH_PORT=8021
FREESWITCH_SECRET=JambonzR0ck$

# ====================================
# FreePBX / SIP Configuration
# ====================================

# Your FreePBX server hostname or IP
SIP_DOMAIN=your-freepbx-server.org
SIP_REGISTRAR=10.0.0.50
SIP_REGISTRAR_PORT=5060
SIP_EXPIRY=3600

# Default extension for outbound calls
SIP_EXTENSION=9000
SIP_AUTH_ID=your-auth-id
SIP_PASSWORD=your-password

# SIP Trunk Config for Outbound (Optional)
SIP_TRUNK_HOST=10.70.7.50
SIP_AUTH_USERNAME=
SIP_AUTH_PASSWORD=
DEFAULT_CALLER_ID=+15551234567

# ====================================
# AI & Speech Configuration
# ====================================

# Ollama Model Config
OLLAMA_API_URL=http://host.docker.internal:11434
OLLAMA_MODEL=deepseek-r1:8b

# TTS - Voxtral TTS via vLLM-Omni (local)
LOCAL_TTS_URL=http://127.0.0.1:8000/v1/audio/speech
VOXTRAL_MODEL=mistralai/Voxtral-4B-TTS-2603
VOXTRAL_VOICE=professional_female
HF_TOKEN=

# STT - Whisper (local)
LOCAL_STT_URL=http://127.0.0.1:8080/v1
WHISPER_MODEL=whisper-1

# Optional Voicemail directory mount for playback
VOICEMAIL_DIR=/var/spool/asterisk/voicemail/default

# ====================================
# Application Settings
# ====================================

# HTTP server port for API and audio file serving
HTTP_PORT=3000

# WebSocket port for audio streaming from FreeSWITCH
WS_PORT=3001

# Audio MIX type. "L" for caller, "R" for callee, or "mixed"
AUDIO_FORK_MIXTYPE=L

# Audio files directory
AUDIO_DIR=/app/audio

# Optional friendly name for the instance
INSTANCE_NAME=Main

# Enable debug logging for specific modules
# DEBUG=voice-app:*

